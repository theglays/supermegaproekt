  itemName: "\u041E\u043A\u043D\u043E "
  interactionDescription: "\u0417\u0430 \u0441\u0442\u0435\u043A\u043B\u043E\u043C
    \u2014 \u043D\u043E\u0447\u043D\u043E\u0439 \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433.
    \u0422\u0443\u0441\u043A\u043B\u044B\u0435 \u0444\u043E\u043D\u0430\u0440\u0438
    \u041D\u0435\u0432\u0441\u043A\u043E\u0433\u043E, \u0441\u0438\u043B\u0443\u044D\u0442\u044B
    \u043C\u043E\u0441\u0442\u043E\u0432 \u0438 \u0442\u044F\u0436\u0451\u043B\u044B\u0439
    \u0442\u0443\u043C\u0430\u043D \u043D\u0430\u0434 \u041D\u0435\u0432\u043E\u0439.
    \u0413\u043E\u0440\u043E\u0434 \u0436\u0438\u0432\u0451\u0442 \u0441\u0432\u043E\u0435\u0439
    \u0436\u0438\u0437\u043D\u044C\u044E."
